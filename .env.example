# Database
DATABASE_URL=sqlite+aiosqlite:///./weft.db

# Security
SECRET_KEY=change-me-to-a-random-secret

# App
BASE_URL=http://localhost:5173
CREATOR_TRANSFER_DEADLINE_HOURS=24
AUTO_ARCHIVE_DAYS=30
TOPIC_CREATION_RATE_LIMIT=10/hour

# ── Email provider ────────────────────────────────────────────────────────────
# Select one: "resend" | "mailgun" | "ses"
EMAIL_PROVIDER=resend
EMAIL_FROM_ADDRESS=Weft <noreply@weft.app>

# Resend (https://resend.com)
RESEND_API_KEY=

# Mailgun (https://mailgun.com)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# ── SMS provider ──────────────────────────────────────────────────────────────
# Select one: "twilio" | "sns" | "vonage"
SMS_PROVIDER=twilio

# Twilio (https://twilio.com)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Vonage (https://vonage.com)
# Note: alphanumeric sender IDs are blocked in US/Canada — use a virtual number there.
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_FROM_SENDER=

# ── AWS (shared by SES email provider and SNS SMS provider) ──────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# SNS sender ID (optional, displayed as sender name on supported carriers)
SNS_SENDER_ID=Weft

# ── Attachment storage ────────────────────────────────────────────────────────
# Select one: "local" | "s3"
ATTACHMENT_STORAGE=local

# Local storage path (used when ATTACHMENT_STORAGE=local)
ATTACHMENT_LOCAL_PATH=./attachments

# S3 storage (used when ATTACHMENT_STORAGE=s3)
ATTACHMENT_S3_BUCKET=
ATTACHMENT_S3_PREFIX=attachments/

# Maximum attachment size in bytes (default: 10 MB)
ATTACHMENT_MAX_SIZE_BYTES=10485760
